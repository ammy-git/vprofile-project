pipeline {
    agent any

    tools {
        maven 'maven'
    }

    stages {
        stage('Checkout Github') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/atulkamble/DevOpsProject.git'
            }
        }

        stage('Maven Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Building docker image') {
            steps {
                sh 'docker build -t nielitdev:v1 .'
            }
        }

        stage('Docker Image push to Dockerhub') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker-cred', url: 'https://index.docker.io/v1/') {
                        sh 'docker tag nielitdev:v1 ammydock/nielitdev:v1'
                        sh 'docker push ammydock/nielitdev:v1'
                    }
                }
            }
        }
    }
}
